{
  "name": "markdown-wysiwyg",
  "displayName": "Markdown WYSIWYG",
  "description": "WYSIWYG-like markdown editing using decorations — hides syntax on inactive lines, reveals on cursor line",
  "version": "0.1.0",
  "publisher": "gauravsett",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Markdown WYSIWYG",
      "properties": {
        "markdown-wysiwyg.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable WYSIWYG markdown decorations"
        },
        "markdown-wysiwyg.headings.scaleFontSize": {
          "type": "boolean",
          "default": true,
          "description": "Scale heading font sizes (H1 largest, H6 smallest)"
        },
        "markdown-wysiwyg.headings.fontSizeScale": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 6,
          "maxItems": 6,
          "default": [
            1,
            1,
            1,
            1,
            1,
            1
          ],
          "description": "Font size multipliers for H1–H6 relative to editor.fontSize (only used when scaleFontSize is true)"
        },
        "markdown-wysiwyg.fontFamily": {
          "type": "string",
          "default": "system-ui, -apple-system, sans-serif",
          "description": "Font family for prose content (headings, paragraphs, lists, blockquotes). Code blocks and inline code keep the editor's monospace font."
        },
        "markdown-wysiwyg.math.enable": {
          "type": "boolean",
          "default": true,
          "description": "Render inline LaTeX math ($...$) as formatted equations"
        }
      }
    },
    "colors": [
      {
        "id": "markdownWysiwyg.inlineCodeBackground",
        "description": "Background color for inline code",
        "defaults": {
          "dark": "rgba(128,128,128,0.15)",
          "light": "rgba(128,128,128,0.12)",
          "highContrast": "rgba(128,128,128,0.2)"
        }
      },
      {
        "id": "markdownWysiwyg.codeBlockBackground",
        "description": "Background color for code blocks",
        "defaults": {
          "dark": "rgba(128,128,128,0.1)",
          "light": "rgba(128,128,128,0.08)",
          "highContrast": "rgba(128,128,128,0.15)"
        }
      },
      {
        "id": "markdownWysiwyg.blockquoteBar",
        "description": "Color for blockquote left bar",
        "defaults": {
          "dark": "rgba(128,128,128,0.5)",
          "light": "rgba(100,100,100,0.4)",
          "highContrast": "rgba(200,200,200,0.6)"
        }
      },
      {
        "id": "markdownWysiwyg.tableHeaderBackground",
        "description": "Background color for table header row",
        "defaults": {
          "dark": "rgba(128,128,128,0.15)",
          "light": "rgba(128,128,128,0.12)",
          "highContrast": "rgba(128,128,128,0.2)"
        }
      },
      {
        "id": "markdownWysiwyg.tableRowOddBackground",
        "description": "Background color for odd table data rows",
        "defaults": {
          "dark": "rgba(128,128,128,0.06)",
          "light": "rgba(128,128,128,0.05)",
          "highContrast": "rgba(128,128,128,0.1)"
        }
      },
      {
        "id": "markdownWysiwyg.tableRowEvenBackground",
        "description": "Background color for even table data rows",
        "defaults": {
          "dark": "rgba(128,128,128,0.02)",
          "light": "rgba(128,128,128,0.01)",
          "highContrast": "rgba(128,128,128,0.04)"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "mathjax-full": "^3.2.1"
  }
}
